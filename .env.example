# Supabase — leave unset to run the UI in demo mode with bundled data
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service-role key: payment intents + gateway callbacks only (server-side)
SUPABASE_SERVICE_ROLE_KEY=

NEXT_PUBLIC_SITE_URL=http://localhost:3000

# eSewa ePay v2 (test creds: product code EPAYTEST)
ESEWA_ENV=sandbox
ESEWA_PRODUCT_CODE=EPAYTEST
ESEWA_SECRET_KEY=

# Khalti ePayment
KHALTI_ENV=sandbox
KHALTI_SECRET_KEY=
